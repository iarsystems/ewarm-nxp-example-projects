  //HW_PINCTRL_DRIVE13_CLR = 0xFFFFFFFF;
  //HW_PINCTRL_DRIVE13_SET = 0x22222222;
  //HW_PINCTRL_DRIVE14_CLR = 0x00FFFFFF;
  //HW_PINCTRL_DRIVE14_SET = 0x00222222;
  __writeMemory32(0x22222220,0x80018290,"Memory");  
  __writeMemory32(0x22222222,0x800182A0,"Memory");  
  __writeMemory32(0x22200222,0x800182B0,"Memory");  
  __writeMemory32(0x22222222,0x800182C0,"Memory");  
  __writeMemory32(0x22222222,0x800182D0,"Memory");  
  __writeMemory32(0x00222222,0x800182E0,"Memory");  
  
  /*Pin Mux*/
  //HW_PINCTRL_MUXSEL4_CLR = 0xFFFC0000;
  //HW_PINCTRL_MUXSEL5_CLR = 0xFC3FFFFF;
  //HW_PINCTRL_MUXSEL6_CLR = 0xFFFFFFFF;
  //HW_PINCTRL_MUXSEL7_CLR = 0x00000FFF;
  __writeMemory32(0xFFFC0000,0x80018148,"Memory");  
  __writeMemory32(0xFC3FFFFF,0x80018158,"Memory");  
  __writeMemory32(0xFFFFFFFF,0x80018168,"Memory");  
  __writeMemory32(0x00000FFF,0x80018178,"Memory");  
  
  /*SDRAM Init*/
  //HW_EMI_CTRL_bit.SFTRST = 0;
  //HW_EMI_CTRL_bit.MEM_WIDTH = 1;
  __writeMemory32(0x1C084040,0x80020000,"Memory");  
  
  //HW_DRAM_CTL00 = 0x01010001;
  //HW_DRAM_CTL01 = 0x00010100;
  //HW_DRAM_CTL02 = 0x01000101;
  //HW_DRAM_CTL03 = 0x00000001;
  //HW_DRAM_CTL04 = 0x00000101;
  //HW_DRAM_CTL05 = 0x00000000;
  //HW_DRAM_CTL06 = 0x00010000;
  //HW_DRAM_CTL07 = 0x01000001;
  //HW_DRAM_CTL09 = 0x00000001;
  //HW_DRAM_CTL10 = 0x07000200;
  //HW_DRAM_CTL11 = 0x00070202;
  //HW_DRAM_CTL12 = 0x02020000;
  //HW_DRAM_CTL13 = 0x04040a01;
  //HW_DRAM_CTL14 = 0x00000203;
  //HW_DRAM_CTL15 = 0x02040000;
  //HW_DRAM_CTL16 = 0x02000000;
  //HW_DRAM_CTL17 = 0x19000f08;
  //HW_DRAM_CTL18 = 0x0d0d0000;
  //HW_DRAM_CTL19 = 0x02021313;
  //HW_DRAM_CTL20 = 0x02061521;
  //HW_DRAM_CTL21 = 0x0000000a;
  //HW_DRAM_CTL22 = 0x00080008;
  //HW_DRAM_CTL23 = 0x00200020;
  //HW_DRAM_CTL24 = 0x00200020;
  //HW_DRAM_CTL25 = 0x00200020;
  //HW_DRAM_CTL26 = 0x000003f7;
  //HW_DRAM_CTL29 = 0x00000020;
  //HW_DRAM_CTL30 = 0x00000020;
  //HW_DRAM_CTL31 = 0x00c80000;
  //HW_DRAM_CTL32 = 0x000a23cd;
  //HW_DRAM_CTL33 = 0x000000c8;
  //HW_DRAM_CTL34 = 0x00006665;
  //HW_DRAM_CTL36 = 0x00000101;
  //HW_DRAM_CTL37 = 0x00040001;
  //HW_DRAM_CTL38 = 0x00000000;
  //HW_DRAM_CTL39 = 0x00000000;
  //HW_DRAM_CTL40 = 0x00010000;
  //HW_DRAM_CTL08 = 0x01010000;
  __writeMemory32(0x01010001,0x800E0000,"Memory");  
  __writeMemory32(0x00010100,0x800E0004,"Memory");  
  __writeMemory32(0x01000101,0x800E0008,"Memory");  
  __writeMemory32(0x00000001,0x800E000C,"Memory");  
  __writeMemory32(0x00000101,0x800E0010,"Memory");  
  __writeMemory32(0x00000000,0x800E0014,"Memory");  
  __writeMemory32(0x00010000,0x800E0018,"Memory");  
  __writeMemory32(0x01000001,0x800E001C,"Memory");  
  __writeMemory32(0x00000001,0x800E0024,"Memory");  
  __writeMemory32(0x07000200,0x800E0028,"Memory");  
  __writeMemory32(0x00070202,0x800E002C,"Memory");  
  __writeMemory32(0x02020000,0x800E0030,"Memory");  
  __writeMemory32(0x04040a01,0x800E0034,"Memory");  
  __writeMemory32(0x00000203,0x800E0038,"Memory");  
  __writeMemory32(0x02040000,0x800E003C,"Memory");  
  __writeMemory32(0x02000000,0x800E0040,"Memory");  
  __writeMemory32(0x19000f08,0x800E0044,"Memory");  
