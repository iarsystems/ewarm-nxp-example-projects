  __writeMemory32(0x02021313,0x800E004C,"Memory");  
  __writeMemory32(0x02061521,0x800E0050,"Memory");  
  __writeMemory32(0x0000000a,0x800E0054,"Memory");  
  __writeMemory32(0x00080008,0x800E0058,"Memory");  
  __writeMemory32(0x00200020,0x800E005C,"Memory");  
  __writeMemory32(0x00200020,0x800E0060,"Memory");  
  __writeMemory32(0x00200020,0x800E0064,"Memory");  
  __writeMemory32(0x000003f7,0x800E0068,"Memory");  
  __writeMemory32(0x00000020,0x800E0074,"Memory");  
  __writeMemory32(0x00000020,0x800E0078,"Memory");
  __writeMemory32(0x00c80000,0x800E007C,"Memory");  
  __writeMemory32(0x000a23cd,0x800E0080,"Memory");  
