  __writeMemory32(0x00010000,0x800E00A0,"Memory");
  __writeMemory32(0x01010000,0x800E0020,"Memory");
  
  //HW_DRAM_CTL16_bit.LOWPOWER_CONTROL = 0x08;
  //HW_DRAM_CTL16_bit.LOWPOWER_AUTO_ENABLE = 0x08;
  __writeMemory32(0x02080800,0x800E0040,"Memory");
}

execUserPreload()
{ 
  //__hwReset(0);
  __message "---- execUserPreload ----" ;
  __MMU_Disable();
  __Power_Init();
  __Clock_Init();
  __EMI_Init();
  
}

execUserReset()
{
  __message "---- execUserReset ----" ;
  __MMU_Disable();

}
