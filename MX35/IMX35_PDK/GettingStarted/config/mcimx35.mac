execUserPreload()
{
__var Reg;
  __hwReset(0);

  // Disable MMU and enable ICache
  Reg = __jtagCP15ReadReg(1, 0, 0, 0);
  Reg &= 0xFFFFFFFA;
  Reg |= 1<<12;
  __jtagCP15WriteReg(1, 0, 0, 0, Reg);

  /*Disable Watchdog Power Down Counter*/
  //WMCR_bit.PDE = 0;
  __writeMemory16(0x0000, 0x53FDC008, "Memory");
}
