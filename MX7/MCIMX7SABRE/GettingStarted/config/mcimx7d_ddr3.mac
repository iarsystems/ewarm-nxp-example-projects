//=============================================================================		
// init script for i.MX7D 	DDR3	
//=============================================================================		
// Revision History		
//  0.9		
//=============================================================================		
		
execUserPreload()
{
  __disable_MMU();
  __init_clock_iomux();
  __init_ddr();
  __init_phy();
  __init_final_start();
}

__disable_MMU()
{
__var Reg;

  /*Disable MMU*/
  Reg = __jtagCP15ReadReg(1, 0, 0, 0);
  Reg &= 0xFFFFDFFA;
  Reg |= 1<<12;
  __jtagCP15WriteReg(1, 0, 0, 0, Reg);
}

