//=============================================================================		
// DDR Controller Registers		
//=============================================================================		
// Memory type:	DDR3	
// Manufacturer:	Micron	
// Device Part Number:	MT41K256M16HA-125:E	
// Clock Freq.: 	533MHz	
// Density per CS in Gb: 	8	
// Chip Selects used:	1	
// Number of Banks:	8	
// Row address:    	15	
// Column address: 	10	
// Data bus width:	32	
// ROW-BANK interleave:	DISABLED	
//=============================================================================		
__init_ddr()
{	
  __writeMemory32(0x00000002,0x30391000,"Memory"); // deassert presetn	
  __writeMemory32(0x01040001,0x307A0000,"Memory"); // DDRC_MSTR	
  __writeMemory32(0x00400046,0x307A0064,"Memory"); // DDRC_RFSHTMG	
  __writeMemory32(0x00000001,0x307a0490,"Memory"); // DDRC_PCTRL_0	
  __writeMemory32(0x00690000,0x307A00D4,"Memory"); // DDRC_INIT1 (if using LPDDR3/LPDDR2, this line is automatically commented out)	
  __writeMemory32(0x00020083,0x307A00D0,"Memory"); // DDRC_INIT0	
//  __writeMemory32(0x00000000,0x307A00D8,"Memory"); // DDRC_INIT2  (if using DDR3 or LPDDR3 this line is automatically commented out) 	
  __writeMemory32(0x09300004,0x307A00DC,"Memory"); // DDRC_INIT3	
  __writeMemory32(0x04080000,0x307A00E0,"Memory"); // DDRC_INIT4	
  __writeMemory32(0x00100004,0x307A00E4,"Memory"); // DDRC_INIT5	
  __writeMemory32(0x0000033F,0x307A00F4,"Memory"); // DDRC_RANKCTL	
  __writeMemory32(0x09081109,0x307A0100,"Memory"); // DDRC_DRAMTMG0	
  __writeMemory32(0x0007020D,0x307A0104,"Memory"); // DDRC_DRAMTMG1	
  __writeMemory32(0x03040407,0x307A0108,"Memory"); // DDRC_DRAMTMG2	
  __writeMemory32(0x00002006,0x307A010C,"Memory"); // DDRC_DRAMTMG3	
  __writeMemory32(0x04020205,0x307A0110,"Memory"); // DDRC_DRAMTMG4	
  __writeMemory32(0x03030202,0x307A0114,"Memory"); // DDRC_DRAMTMG5	
//  __writeMemory32(0x02020005,0x307A0118,"Memory"); // DDRC_DRAMTMG6	
//  __writeMemory32(0x00000202,0x307A011C,"Memory"); // DDRC_DRAMTMG7	
  __writeMemory32(0x00000803,0x307A0120,"Memory"); // DDRC_DRAMTMG8	
  __writeMemory32(0x00800020,0x307A0180,"Memory"); // DDRC_ZQCTL0	
//  __writeMemory32(0x02000100,0x307A0184,"Memory"); // DDRC_ZQCTL1	
  __writeMemory32(0x02098204,0x307A0190,"Memory"); // DDRC_DFITMG0	
  __writeMemory32(0x00030303,0x307A0194,"Memory"); // DDRC_DFITMG1	
  __writeMemory32(0x80400003,0x307A01A0,"Memory"); // DDRC_DFIUPD0	
  __writeMemory32(0x00100020,0x307A01A4,"Memory"); // DDRC_DFIUPD1	
  __writeMemory32(0x80100004,0x307A01A8,"Memory"); // DDRC_DFIUPD2	
  __writeMemory32(0x00000016,0x307A0200,"Memory"); // DDRC_ADDRMAP0	
  __writeMemory32(0x00171717,0x307A0204,"Memory"); // DDRC_ADDRMAP1	
  __writeMemory32(0x00000F0F,0x307A0210,"Memory"); // DDRC_ADDRMAP4	
  __writeMemory32(0x04040404,0x307A0214,"Memory"); // DDRC_ADDRMAP5	
  __writeMemory32(0x0F040404,0x307A0218,"Memory"); // DDRC_ADDRMAP6	
  __writeMemory32(0x06000604,0x307A0240,"Memory"); // DDRC_ODTCFG	
  __writeMemory32(0x00000001,0x307A0244,"Memory"); // DDRC_ODTMAP	
}

//=============================================================================		
// PHY Control Registers		
//=============================================================================		
__init_phy()
{
  __writeMemory32(0x00000000,0x30391000,"Memory"); // deassert presetn	
  __writeMemory32(0x17420F40,0x30790000,"Memory"); // DDR_PHY_PHY_CON0	
  __writeMemory32(0x10210100,0x30790004,"Memory"); // DDR_PHY_PHY_CON1	
//  __writeMemory32(0x00010000,0x30790008,"Memory"); // DDR_PHY_PHY_CON2 (if using DDR3 this line is automatically commented out) 	
  __writeMemory32(0x00060807,0x30790010,"Memory"); // DDR_PHY_PHY_CON4	
  __writeMemory32(0x1010007E,0x307900B0,"Memory"); // DDR_PHY_MDLL_CON0 	
//  __writeMemory32(0x01010000,0x3079001C,"Memory"); // DDR_PHY_PHY_RODT_CON0 (if using DDR3 this line is automatically commented out) 	
  __writeMemory32(0x00000D6E,0x3079009C,"Memory"); // DDR_PHY_DRVDS_CON0	
 		
//  __writeMemory32(0x00000001,0x30790078,"Memory); // DDR_PHY_WR_LVL_CON3 - Optional write leveling resync enable, uncomment to invoke	
//  __writeMemory32(0x00000000,0x3079006C,"Memory); // DDR_PHY_WR_LVL_CON0 - Optional write leveling values for each byte lane, uncomment to invoke	
//  __writeMemory32(0x00000000,0x30790078,"Memory); // DDR_PHY_WR_LVL_CON3 - Optional write leveling resync disable, uncomment to invoke 	
 		
  __writeMemory32(0x08080808,0x30790030,"Memory"); // DDR_PHY_OFFSET_WR_CON0	
  __writeMemory32(0x08080808,0x30790020,"Memory"); // DDR_PHY_OFFSET_RD_CON0	
  __writeMemory32(0x01000010,0x30790050,"Memory"); // DDR_PHY_OFFSETD_CON0	
  __writeMemory32(0x00000010,0x30790050,"Memory"); // DDR_PHY_OFFSETD_CON0	
  __writeMemory32(0x0000000F,0x30790018,"Memory"); // DDR_PHY_LP_CON0	
  __writeMemory32(0x0E407304,0x307900C0,"Memory"); // DDR_PHY_ZQ_CON0 - Start Manual ZQ	
  __writeMemory32(0x0E447304,0x307900C0,"Memory"); //
  __writeMemory32(0x0E447306,0x307900C0,"Memory"); //
  __writeMemory32(0x0E447304,0x307900C0,"Memory"); //

  __writeMemory32(0x0E407304,0x307900C0,"Memory"); // DDR_PHY_ZQ_CON0 - End Manual ZQ	
}
		
//=============================================================================		
// Final Initialization start sequence		
//=============================================================================		
__init_final_start()
{		
  __writeMemory32(0x00000000,0x30384130,"Memory"); // Disable Clock	
  __writeMemory32(0x00000178,0x30340020,"Memory"); // IOMUX_GRP_GRP8 - Start input to PHY	
  __writeMemory32(0x00000002,0x30384130,"Memory"); // Enable Clock	
}		

